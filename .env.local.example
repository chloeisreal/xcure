# ===========================================
# XCure Valuation Engine - Environment Variables
# ===========================================

# -------------------------------------------------
# Required API Keys
# -------------------------------------------------

# MiniMax API (必需 - 用于 AI 估值分析)
# 获取地址: https://platform.minimax.com/
# 端点: https://api.minimax.io
# 模型: M2.5
MINIMAX_API_KEY=your-minimax-api-key

# -------------------------------------------------
# Optional API Keys
# -------------------------------------------------

# Financial Modeling Prep (可选 - 财务数据备选源)
# 免费注册: https://site.financialmodelingprep.com/
FMP_API_KEY=your-fmp-api-key

# WalletConnect Project ID (可选 - 用于钱包连接)
# 获取地址: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
